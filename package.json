  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.9.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5"
  }
}